# ============================================
# Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================

# === Database ===
# Vercel Postgres, Supabase, or local PostgreSQL
# Example (Supabase):
#   postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# Example (Vercel Postgres):
#   postgresql://[user]:[password]@[host]/[db]?sslmode=require
DATABASE_URL=""

# === NextAuth v5 (Auth.js) ===
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Production: https://yourdomain.com
# Development: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# === Email Provider (Resend recommended for production) ===
# Sign up at https://resend.com
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@yourdomain.com"

# === Optional: Vercel Blob (for image upload storage) ===
# Sign up at https://vercel.com/docs/storage/vercel-blob
# BLOB_READ_WRITE_TOKEN=""

# === Optional: Bundle Analyzer ===
# Set to "true" to enable: npm run analyze
# ANALYZE="false"
